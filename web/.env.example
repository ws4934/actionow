# Environment Variables Example
# Copy this file to .env.local and update the values

# API Base URL (used by the server-side /api proxy)
# Local: http://127.0.0.1:8080 or http://localhost:8088
# Production: https://api.actionow.ai
API_BASE_URL=http://127.0.0.1:8080

# Optional local-only escape hatch for broken backend TLS chains.
# Never enable this in production.
# API_ALLOW_INSECURE_TLS=true

# Optional legacy fallback for code paths not yet migrated.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# WebSocket URL (used directly by the browser)
# Local: ws://127.0.0.1:8080/ws
# Production: wss://api.actionow.ai/ws
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8080/ws

# Site URL (for SEO and sharing)
# Local: http://localhost:3000
# Production: https://actionow.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000
