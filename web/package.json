{
  "name": "actionow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pm2": "next build && node scripts/prepare-standalone.cjs",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint",
    "build:cf": "opennextjs-cloudflare build",
    "build:worker": "opennextjs-cloudflare build",
    "dev:worker": "wrangler dev --port 8771",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "API_BASE_URL=https://api.actionow.ai NEXT_PUBLIC_WS_URL=wss://api.actionow.ai/ws NEXT_PUBLIC_SITE_URL=https://actionow.ai opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@heroui/react": "^3.0.0-rc.1",
    "@heroui/styles": "^3.0.0-rc.1",
    "@ozdemircibaris/react-image-editor": "^1.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-codemirror": "^4.23.10",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-use-websocket": "^4.13.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.67.1"
  }
}
