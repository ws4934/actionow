# =====================================================
# Actionow Docker Environment Configuration
# Copy this file to .env (development) or .env.prod (production)
#
# For apps-only mode (COMPOSE_MODE=apps):
#   Copy to .env.apps and change infrastructure hosts to 127.0.0.1
# =====================================================

# =====================================================
# Common Configuration
# =====================================================
COMPOSE_PROJECT_NAME=actionow
TZ=Asia/Shanghai

# Spring Profile: dev / docker / prod
SPRING_PROFILES_ACTIVE=docker

# Log Level: DEBUG / INFO / WARN / ERROR
LOG_LEVEL=INFO

# =====================================================
# PostgreSQL Database
# For external database: set DB_HOST to your server address
# For Docker database: use default (postgres)
# For apps mode: use 127.0.0.1
# =====================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=actionow
DB_USER=actionow
DB_PASSWORD=actionow123

# Expose port for external access (Docker mode only)
POSTGRES_EXPOSE_PORT=5432

# =====================================================
# Redis Cache
# For external Redis: set REDIS_HOST to your server address
# For Docker Redis: use default (redis)
# For apps mode: use 127.0.0.1
# =====================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Expose port for external access (Docker mode only)
REDIS_EXPOSE_PORT=6379

# =====================================================
# RabbitMQ Message Queue
# For external RabbitMQ: set RABBITMQ_HOST to your server address
# For Docker RabbitMQ: use default (rabbitmq)
# For apps mode: use 127.0.0.1
# =====================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=actionow
RABBITMQ_PASSWORD=actionow123
RABBITMQ_VHOST=/
RABBITMQ_SSL_ENABLED=false

# Expose ports for external access (Docker mode only)
RABBITMQ_EXPOSE_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# =====================================================
# Object Storage Configuration
# Choose one: minio / s3 / aliyun / r2 / tos
# =====================================================
OSS_TYPE=minio

# Optional: Custom domain for public access (applies to all providers)
OSS_DOMAIN=

# --- MinIO Configuration (when OSS_TYPE=minio) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=actionow
MINIO_SECRET_KEY=actionow123
MINIO_BUCKET_NAME=actionow-assets
# MinIO container admin credentials (Docker infra only)
MINIO_ROOT_USER=actionow
MINIO_ROOT_PASSWORD=actionow123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- AWS S3 Configuration (when OSS_TYPE=s3) ---
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET=
S3_TRANSFER_ACCELERATION=false
S3_CLOUDFRONT_DOMAIN=
S3_CLOUDFRONT_KEY_PAIR_ID=
S3_CLOUDFRONT_PRIVATE_KEY_PATH=
S3_PRESIGNED_EXPIRE=3600

# --- Cloudflare R2 Configuration (when OSS_TYPE=r2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_DOMAIN=
R2_PRESIGNED_EXPIRE=3600

# --- Aliyun OSS Configuration (when OSS_TYPE=aliyun) ---
ALIYUN_ENDPOINT=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_BUCKET=
ALIYUN_INTERNAL_ENDPOINT=
ALIYUN_PRESIGNED_EXPIRE=3600

# --- Volcengine TOS Configuration (when OSS_TYPE=tos) ---
TOS_ENDPOINT=tos-cn-guangzhou.volces.com
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_BUCKET=
TOS_REGION=cn-guangzhou
TOS_PUBLIC_DOMAIN=
TOS_PRESIGNED_EXPIRE=3600

# =====================================================
# Security Configuration
# IMPORTANT: Change these values in production!
# =====================================================
JWT_SECRET=actionow-development-jwt-secret-key-change-in-production

# Internal Service Authentication (HMAC signing between gateway and services)
# IMPORTANT: Generate a random 64-char hex string for production
INTERNAL_AUTH_SECRET=CHANGE_ME_TO_RANDOM_HEX_64

# =====================================================
# Billing / Stripe
# =====================================================
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# IMPORTANT: Change to your actual frontend domain in production!
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel
BILLING_SUBSCRIPTION_CURRENCY=USD
BILLING_POINTS_PER_MAJOR_UNIT=10
BILLING_MINOR_PER_MAJOR_UNIT=100

# WeChat Pay (Native scan-to-pay for topup)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY_PATH=classpath:cert/apiclient_key.pem
WECHAT_MCH_SERIAL_NUMBER=
# IMPORTANT: Change to your actual public API domain in production!
WECHAT_NOTIFY_URL=http://localhost:8092/billing/callback/WECHATPAY

# =====================================================
# Service Ports
# =====================================================
GATEWAY_PORT=8080
USER_PORT=8081
WORKSPACE_PORT=8082
WALLET_PORT=8083
PROJECT_PORT=8084
AI_PORT=8086
TASK_PORT=8087
COLLAB_PORT=8088
SYSTEM_PORT=8089
CANVAS_PORT=8090
AGENT_PORT=8091
BILLING_PORT=8092

# =====================================================
# Service URL Overrides (apps mode only)
# When using COMPOSE_MODE=apps with host network, uncomment and set these
# to 127.0.0.1 addresses. In Docker bridge mode they resolve automatically.
# =====================================================
#USER_SERVICE_URL=http://127.0.0.1:8081
#WORKSPACE_SERVICE_URL=http://127.0.0.1:8082
#WALLET_SERVICE_URL=http://127.0.0.1:8083
#PROJECT_SERVICE_URL=http://127.0.0.1:8084
#AI_SERVICE_URL=http://127.0.0.1:8086
#TASK_SERVICE_URL=http://127.0.0.1:8087
#COLLAB_SERVICE_URL=http://127.0.0.1:8088
#SYSTEM_SERVICE_URL=http://127.0.0.1:8089
#CANVAS_SERVICE_URL=http://127.0.0.1:8090
#AGENT_SERVICE_URL=http://127.0.0.1:8091
#BILLING_SERVICE_URL=http://127.0.0.1:8092
#COLLAB_WS_URL=ws://127.0.0.1:8088
#CANVAS_WS_URL=ws://127.0.0.1:8090

# =====================================================
# JVM Configuration
# Heap is auto-sized by MaxRAMPercentage=75% of container memory limit.
# No explicit -Xms/-Xmx needed — just tune container memory limits below.
# =====================================================
JVM_OPTS=-XX:MaxGCPauseMillis=200 -XX:+UseStringDeduplication

# Per-service container memory limits
GATEWAY_MEMORY=1G
USER_MEMORY=1G
WORKSPACE_MEMORY=1G
WALLET_MEMORY=1G
PROJECT_MEMORY=1G
AI_MEMORY=2G
TASK_MEMORY=1G
COLLAB_MEMORY=1G
SYSTEM_MEMORY=1G
CANVAS_MEMORY=1G
AGENT_MEMORY=2G
BILLING_MEMORY=1G

# =====================================================
# AI Provider API Keys (Optional)
# =====================================================

# OpenAI (GPT-4, DALL-E)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Stability AI (Stable Diffusion)
STABILITY_API_KEY=

# Dify Integration
DIFY_BASE_URL=http://localhost:5001

# Groovy Sandbox (AI service script execution timeout)
GROOVY_MAX_EXECUTION_TIME_MS=120000

# =====================================================
# Google Cloud / Vertex AI
# =====================================================
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Embedding Model (used by agent service for RAG)
EMBEDDING_MODEL=text-embedding-004

# ADK (Agent Development Kit) Configuration
ADK_MODEL=gemini-2.0-flash
ADK_MAX_ITERATIONS=15

# =====================================================
# Agent (SAA - Spring AI Alibaba) Configuration
# =====================================================

# Default LLM model ID (from t_llm_provider table)
SAA_DEFAULT_MODEL=gemini-3-flash-preview

# Max ReAct iterations per request
SAA_MAX_ITERATIONS=20

# Enable RAG (vector memory) - requires pgvector
RAG_ENABLED=false

# Agent Billing Configuration
BILLING_IDLE_TIMEOUT=30
BILLING_BATCH_SIZE=50
BILLING_MAX_RETRY=3

# Agent Session Configuration
SESSION_MAX_ACTIVE_PER_SCOPE=5
SESSION_MAX_ACTIVE_GLOBAL=3
SESSION_MAX_TOTAL_PER_USER=200

# Skill Package (OSS ZIP)
# Optional: URL of a ZIP file containing .md skill definitions (supports presigned URLs)
# Format: each .md file has YAML frontmatter (displayName/description/groupedToolIds/enabled)
#         followed by the skill's system prompt as body.
# Leave empty to manage skills only through the Admin API (DB CRUD mode).
SKILL_PACKAGE_URL=

# Agent Billing Scheduler
BILLING_SETTLE_INTERVAL=300000
BILLING_RETRY_INTERVAL=600000

# Agent Session Lifecycle
SESSION_IDLE_ARCHIVE_DAYS=30
SESSION_SOFT_DELETE_RETENTION=90
SESSION_BATCH_SIZE=100

# Agent Mission (Autonomous Execution)
MISSION_MAX_STEPS=50
MISSION_MAX_RETRIES=3
MISSION_MAX_CONTEXT_STEPS=10
MISSION_MAX_STEP_SUMMARY_CHARS=500
MISSION_LOOP_WARN_THRESHOLD=5
MISSION_LOOP_FAIL_THRESHOLD=10

# =====================================================
# OAuth Configuration
# OAuth 配置已迁移至 t_system_config，请通过 System 管理面板配置
# =====================================================

# =====================================================
# Mail Configuration
# Provider: resend (recommended) / smtp / cloudflare
# Provider can be hot-switched at runtime via MailRuntimeConfigService
# =====================================================
MAIL_PROVIDER=resend

# Default sender
MAIL_FROM=support@example.com
MAIL_FROM_NAME=Actionow

# Resend Configuration (when MAIL_PROVIDER=resend)
RESEND_API_KEY=

# SMTP Configuration (when MAIL_PROVIDER=smtp, e.g., AWS SES)
MAIL_HOST=email-smtp.ap-northeast-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Cloudflare Email Sending API (when MAIL_PROVIDER=cloudflare)
CLOUDFLARE_MAIL_ACCOUNT_ID=
CLOUDFLARE_MAIL_API_TOKEN=
CLOUDFLARE_MAIL_API_BASE=https://api.cloudflare.com/client/v4
CLOUDFLARE_MAIL_TIMEOUT_MS=10000

# =====================================================
# Task Service Configuration
# =====================================================
TASK_CALLBACK_BASE_URL=http://actionow-task:8087

# =====================================================
# Web Frontend (Next.js) Configuration
# =====================================================
# Host port the web container listens on
WEB_PORT=3000

# Memory limit for the web container
WEB_MEMORY=1G

# Image tag for the built web image
WEB_IMAGE_TAG=latest

# API base URL used by the server-side /api proxy inside the web container.
# On the Docker network, point to the gateway service.
WEB_API_BASE_URL=http://actionow-gateway:8080

# WebSocket URL exposed to the browser — must be reachable from the client.
WEB_NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Site URL exposed to the browser (SEO / OG / sharing).
WEB_NEXT_PUBLIC_SITE_URL=http://localhost:3000
